#!/bin/sh
# 디자인 기틀 커밋 게이트 (3층 방어의 최종층, 260703)
# index.html·signage 편집이 baseline을 위반한 채 커밋되는 걸 차단.
# 활성화: git config core.hooksPath .githooks  (.claude/hooks/design_digest.py가 세션 시작 시 자동 수행)
ROOT="$(git rev-parse --show-toplevel)"
if [ -f "$ROOT/tools/check_design.py" ]; then
  python3 "$ROOT/tools/check_design.py" || {
    echo "[pre-commit] 디자인 기틀 위반 — 커밋 차단. 위 출력을 보고 수정하거나, 정당한 변경이면 baseline 갱신(사유 주석)." >&2
    exit 1
  }
fi
# 라우터·지침 경로 참조 게이트 (마스터 라우터 기틀)
if [ -f "$ROOT/tools/check_refs.py" ]; then
  python3 "$ROOT/tools/check_refs.py" || {
    echo "[pre-commit] check_refs 위반 — CLAUDE.md·docs/앱지침.md의 백틱 경로가 레포에 없음. 경로 수정 또는 파일 생성 후 커밋." >&2
    exit 1
  }
fi
# 로그인 스모크 게이트 (index.html 변경 시만 실행 · 회귀 발생기=23k 단일파일 로그인흐름 차단)
# fail-soft: node·playwright-core·chromium 미탐지 = 스크립트가 SKIP(차단 안 함). 진짜 로그인 파손만 exit 1.
if [ -f "$ROOT/tools/smoke_login.mjs" ] && command -v node >/dev/null 2>&1; then
  if git diff --cached --name-only | grep -q '^index\.html$'; then
    node "$ROOT/tools/smoke_login.mjs" || {
      echo "[pre-commit] 로그인 스모크 실패 — 로그인 화면 미렌더 또는 JS 회귀 감지. 위 출력 확인·수정(정말 무관하면 git commit --no-verify)." >&2
      exit 1
    }
  fi
fi
exit 0
